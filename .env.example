# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Провайдер суммаризации: none | openai | anthropic
# "none" — локальный алгоритм TextRank, без внешних API и без ключей
LLM_PROVIDER=none

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Меняй только если используешь не официальный OpenAI API, а
# OpenAI-совместимый прокси/агрегатор — впиши его адрес и точное
# название модели из его документации. Для официального API
# просто оставь пустым или закомментируй строку.
# OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest
# Аналогично — только для Anthropic-совместимых прокси/агрегаторов.
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# tiny | base | small | medium
WHISPER_MODEL_SIZE=small

MAX_INPUT_CHARS=60000
CHUNK_SIZE_CHARS=4000
TMP_DIR=tmp_files

# Максимальный размер документа и аудио, которые бот согласится
# скачать и обработать (в МБ)
MAX_DOCUMENT_SIZE_MB=20
MAX_VOICE_SIZE_MB=20

# Минимальный интервал между сообщениями одного пользователя (в секундах)
RATE_LIMIT_SECONDS=3
